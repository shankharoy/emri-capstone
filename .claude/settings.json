{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "description": "Coding and Enterprise Application Settings for Claude Code",

  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(npm:*)",
      "Bash(yarn:*)",
      "Bash(pnpm:*)",
      "Bash(node:*)",
      "Bash(python:*)",
      "Bash(pip:*)",
      "Bash(docker:*)",
      "Bash(kubectl:*)",
      "Bash(gh:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(jq:*)",
      "Bash(terraform:*)",
      "Bash(aws:*)",
      "Bash(gcloud:*)",
      "Bash(az:*)",
      "Bash(make:*)",
      "Bash(mvn:*)",
      "Bash(gradle:*)",
      "Edit(.claude)",
      "Read"
    ],
    "ask": [
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Write(/etc/*)",
      "Edit(/etc/*)"
    ],
    "deny": [
      "Bash(curl *|*sh)",
      "Bash(wget *|*sh)"
    ],
    "defaultMode": "acceptEdits"
  },

  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_response.filePath // .tool_input.file_path' | { read -r f; if [[ \"$f\" =~ \\.(js|ts|jsx|tsx|json|css|scss|md|yml|yaml)$ ]]; then prettier --write \"$f\" 2>/dev/null || true; fi; }",
            "statusMessage": "Formatting code..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\": \"Enterprise coding environment ready. Security checks enabled.\"}'",
            "once": true
          }
        ]
      }
    ]
  },

  "env": {
    "NODE_ENV": "development",
    "PYTHONDONTWRITEBYTECODE": "1",
    "PIP_NO_CACHE_DIR": "1",
    "DOCKER_BUILDKIT": "1",
    "COMPOSE_DOCKER_CLI_BUILD": "1"
  },

  "sandbox": {
    "enabled": true,
    "allowUnsandboxedCommands": false,
    "failIfUnavailable": false,
    "network": {
      "allowLocalBinding": true,
      "allowAllUnixSockets": false
    },
    "filesystem": {
      "allowWrite": [
        "./",
        "./node_modules",
        "./dist",
        "./build",
        "./target",
        "./.venv",
        "./venv"
      ],
      "denyWrite": [
        "/etc",
        "/usr",
        "/bin",
        "/sbin",
        "/lib",
        "/lib64"
      ]
    }
  },

  "worktree": {
    "symlinkDirectories": [
      "node_modules",
      ".cache",
      ".bin"
    ],
    "sparsePaths": [
      "src",
      "packages",
      "apps"
    ]
  },

  "respectGitignore": true,
  "cleanupPeriodDays": 30,
  "alwaysThinkingEnabled": true,
  "fastMode": false,
  "promptSuggestionEnabled": true,
  "showClearContextOnPlanAccept": true,
  "useAutoModeDuringPlan": true,
  "includeGitInstructions": true,

  "attribution": {
    "commit": "Co-Authored-By: Claude <noreply@anthropic.com>",
    "pr": "🤖 Generated with [Claude Code](https://claude.ai/code)"
  },

  "autoMemoryEnabled": true,
  "autoDreamEnabled": true,

  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [],

  "terminalTitleFromRename": true,
  "viewMode": "default",
  "outputStyle": "concise",

  "feedbackSurveyRate": 0.05,
  "spinnerTipsEnabled": true,

  "autoCompactWindow": 500000,

  "proactive": {
    "autoEnable": false
  },

  "voiceEnabled": true,
  "voice": {
    "enabled": true,
    "mode": "hold",
    "autoSubmit": true
  },

  "defaultView": "transcript"
}
